    "C": "Ctrl",
    "A": "Alt",
    "Win": "Windows / Command depending on OS mapping",
    "Win/Cmd": "Windows / Command",
    "Layer(n)": "Momentary/tap layer behavior as printed in the cheatsheet",
    "Lang 1": "Language key 1 as printed",
    "Lang 2": "Language key 2 as printed",
    "▽": "Transparent / pass-through key in Remap display",
    "Kb n": "Keyboard/custom keycode label as printed",
    "UG Bright -": "Underglow brightness down as printed",
    "RGB Mode Twinkle": "RGB mode twinkle as printed",
    "Mouse Btn1": "Mouse button 1",
    "Mouse Btn2": "Mouse button 2"
  },
